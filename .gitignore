# ================================
# PROJECT SPECIFIC (MUSIC PLAYER)
# ================================

# Audio files (don't commit large music files)
**/*.mp3
**/*.wav
**/*.flac
**/*.aac
**/*.ogg
**/*.m4a
# Exception: keep sample/test audio files if small
!**/assets/audio/samples/**
!**/test/fixtures/audio/**

# Album artwork cache
**/album_art_cache/
**/thumbnails/
**/cover_art/

# Music library database files
**/music_library.db
**/music_cache.db
**/playlists.db

# Audio processing temporary files
**/temp_audio/
**/audio_processing/

# User data
**/user_playlists/
**/user_preferences/
**/listening_history/

# API keys and secrets
**/secrets/
**/config/api_keys.*
music-player-backend/src/main/resources/application-secrets.properties
music-player-frontend/lib/config/secrets.dart

# Certificates and keys
**/*.pem
**/*.key
**/*.crt
**/*.p12

# ================================
# DOCUMENTATION & ASSETS
# ================================

# Keep important documentation
!README.md
!LICENSE
!CHANGELOG.md
!docs/

# Keep small asset files
!**/assets/icons/**
!**/assets/images/**
# But ignore large generated assets
**/assets/**/*.generated.*