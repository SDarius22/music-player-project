@startuml flow_app_startup
!theme plain
skinparam defaultFontName monospaced

title User Flow — App Startup

participant "main.dart" as main
participant "MultiProvider\n(abstract_app.dart)" as provider
participant "WebRTCService" as webrtc
participant "LoadingScreen" as loading
participant "UserProvider" as userProv
participant "AuthService" as auth
participant "SecureStorage" as storage
participant "SongService" as songSvc
participant "PlaybackRestService" as playbackRest
participant "AppAudioService" as audioSvc
participant "Backend" as backend

== Initialization ==

main -> main: app initialization (db, audio plugin, etc.)

main -> provider: build MultiProvider tree\n(services, repos, audio, providers)

note over webrtc
  lazy: false — created immediately
  Opens WebSocket to wss://.../ws/signaling
  Registers callbacks:
    onChunkReceived → ActiveChunkRouter
    onChunkRequested → ActiveChunkRouter
    onSyncTrigger → SongService.runSync()
end note

provider -> webrtc: instantiate + connect WS

== Loading Screen ==

provider -> loading: navigate

loading -> userProv: tryAutoLogin()
userProv -> storage: read "refresh_token"

alt refresh token found
  storage --> userProv: token
  userProv -> auth: refreshAccessToken(token)
  auth -> backend: POST /auth/refresh
  backend --> auth: new access_token + refresh_token
  auth -> storage: store new tokens
  auth -> auth: startTokenRefresh()\n(periodic, every 10 min)

  loading -> songSvc: initialize(musicDirs) [desktop]
  songSvc -> songSvc: scan local music directories
  songSvc -> backend: POST /sync (delta, lastSyncTime)\n→ upload missing chunks, apply remote changes

  loading -> playbackRest: getPlaybackState()
  playbackRest -> backend: GET /playback
  backend --> playbackRest: PlaybackStateDto\n(queue, current song, position, shuffle, repeat)
  loading -> audioSvc: restoreFromServerState(state)
  audioSvc -> audioSvc: rebuild audio queue from stored song IDs

  loading -> loading: navigate → MainScaffold

else no token
  loading -> loading: navigate → WelcomeScreen
end

@enduml