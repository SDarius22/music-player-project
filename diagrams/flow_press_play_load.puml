@startuml flow_press_play_load
!theme plain
skinparam defaultFontName monospaced

actor User
participant "AudioProvider" as audioProv
participant "AppAudioService" as audioSvc
participant "P2PChunkedAudioSource\n/ WebP2PBridge" as chunkPath

User -> audioProv: tap Play
audioProv -> audioSvc: play()
audioSvc -> audioSvc: _loadIndex(idx)
audioSvc -> audioSvc: flush previous chunk stats
audioSvc -> audioSvc: _buildAudioSource(song)
audioSvc -> chunkPath: create source\n(native: P2PChunkedAudioSource;\n web: stream URL via WebP2PBridge)
audioSvc -> audioSvc: audioPlayer.setAudioSource(\nsource, initialPosition)
audioSvc -> audioSvc: audioPlayer.play()

@enduml
