@startuml flow_app_quit
!theme plain
skinparam defaultFontName monospaced

title User Flow — App Quit

actor User
participant "OS / Flutter" as os
participant "AudioProvider" as audioProv
participant "AppAudioService" as audioSvc
participant "ChunkService(s)" as chunkSvc
participant "WebRTCService" as webrtc
participant "AuthService" as auth
participant "Backend\nSignalingHandler" as sigBackend
participant "Redis" as redis

User -> os: close app window

== Playback Teardown ==

os -> audioProv: dispose()
audioProv -> audioProv: disposeListeners()\n(drain position / playback streams)
audioProv -> audioSvc: audioPlayer.dispose()
audioSvc -> audioSvc: _positionSaveTimer.cancel()\n(stop 30s state-push timer)
audioSvc -> audioSvc: audioPlayer.dispose()\n(stop playback, release media resources)
audioSvc -> chunkSvc: (ChunkService instances\nnaturally GC'd)

== P2P & Signaling Teardown ==

os -> webrtc: dispose()
webrtc -> webrtc: close all RTCDataChannels
webrtc -> webrtc: close all RTCPeerConnections
webrtc -> webrtc: signalingSocket.sink.close()

note over sigBackend
  Server receives WebSocket close event:
  SignalingHandler.afterConnectionClosed(session)
    → remove session from registry (ConcurrentHashMap)
    → remove session from userIndex[userId]
    → remove peerId from peerIndex
end note

sigBackend -> redis: HDEL peer:chunks:{songId} peerId\n(for every song this peer cached)
sigBackend -> redis: DEL peer:songs:{peerId}

note over redis
  Peer's chunk registrations are removed.
  Other instances no longer advertise
  this peer for P2P chunk requests.
end note

== Auth Teardown ==

os -> auth: stopTokenRefresh()
auth -> auth: cancel periodic refresh Timer

@enduml